---
interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const siteTitle = "kamo-news";
const rssHref = `${import.meta.env.BASE_URL.replace(/\/$/, "")}/rss.xml`;
const homeHref = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title === siteTitle ? title : `${title} | ${siteTitle}`}</title>
    {description && <meta name="description" content={description} />}
    {description && <meta property="og:description" content={description} />}
    <meta property="og:title" content={title} />
    <meta property="og:site_name" content={siteTitle} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${siteTitle} RSS`}
      href={rssHref}
    />
  </head>
  <body>
    <header>
      <div class="wrap">
        <a class="brand" href={homeHref}>{siteTitle}</a>
        <nav>
          <a href={rssHref}>RSS</a>
          <a href="https://github.com/kamo-shika/kamo-news" target="_blank" rel="noopener">GitHub</a>
        </nav>
      </div>
    </header>
    <main class="wrap">
      <slot />
    </main>
    <footer>
      <div class="wrap">
        <small>毎朝 7:00 JST に Claude Code が自動生成する AI トレンドニュース</small>
      </div>
    </footer>
    <style is:global>
      :root {
        --fg: #1a1a1a;
        --fg-muted: #555;
        --bg: #fafafa;
        --bg-card: #fff;
        --accent: #2b6cb0;
        --border: #e2e2e2;
        --max-width: 760px;
        font-family:
          -apple-system, BlinkMacSystemFont, "Hiragino Kaku Gothic ProN",
          "Yu Gothic UI", "Segoe UI", sans-serif;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --fg: #e8e8e8;
          --fg-muted: #a8a8a8;
          --bg: #14181d;
          --bg-card: #1c2128;
          --accent: #79b8ff;
          --border: #30363d;
        }
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body {
        background: var(--bg);
        color: var(--fg);
        line-height: 1.7;
      }
      .wrap { max-width: var(--max-width); margin: 0 auto; padding: 0 1rem; }
      header {
        background: var(--bg-card);
        border-bottom: 1px solid var(--border);
        padding: 0.8rem 0;
      }
      header .wrap { display: flex; justify-content: space-between; align-items: center; }
      .brand { font-weight: 700; font-size: 1.15rem; color: var(--fg); text-decoration: none; }
      nav { display: flex; gap: 1rem; }
      nav a { color: var(--accent); text-decoration: none; font-size: 0.95rem; }
      nav a:hover { text-decoration: underline; }
      main { padding: 2rem 0 4rem; }
      footer { border-top: 1px solid var(--border); padding: 1.2rem 0; }
      footer small { color: var(--fg-muted); }
      a { color: var(--accent); }
      h1, h2, h3 { line-height: 1.35; }
      h2 { border-bottom: 1px solid var(--border); padding-bottom: 0.25rem; margin-top: 2.2rem; }
      h3 { margin-top: 1.8rem; }
      code { background: var(--bg-card); padding: 0.1em 0.35em; border-radius: 3px; font-size: 0.92em; }
      blockquote {
        border-left: 4px solid var(--border);
        padding-left: 1rem;
        color: var(--fg-muted);
        margin-left: 0;
      }
    </style>
  </body>
</html>
